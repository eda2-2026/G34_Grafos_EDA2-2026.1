{
  "name": "techgraph-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "bun --filter backend dev",
    "dev:frontend": "bun --filter frontend dev",
    "dev": "concurrently \"bun run dev:backend\" \"bun run dev:frontend\"",
    "build:shared": "bun --filter shared build",
    "build:backend": "bun --filter backend build",
    "build:frontend": "bun --filter frontend build",
    "build": "bun run build:shared && bun run build:backend && bun run build:frontend"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
